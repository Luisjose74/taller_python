# operadores de comparacion
print (1==1) #si es igual a 1 devuelve true
print (1!=2) #si es diferente de 1 devuelve true
print (2>1) #si es mayor que 1 devuelve true
print (1<2) #si es menor que 2 devuelve true
print (2>=2) #si es mayor o igual que 2 devuelve true
print (1<=2) #si es menor o igual que 1 devuelve true


